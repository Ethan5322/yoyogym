# ============================================================
# PREMIUM AI GYM SYSTEM — ENVIRONMENT VARIABLES
# Copy this file to ".env" and fill in real values.
# NEVER commit ".env". In production, set these in Vercel
# (Project Settings -> Environment Variables).
# ============================================================

# ---- Supabase (SERVER-ONLY — used inside /api functions) ----
# Project URL, e.g. https://abcdxyz.supabase.co
SUPABASE_URL=
# SERVICE ROLE key — bypasses RLS. Server only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Postgres schema that holds this app's tables (we installed into "gym").
SUPABASE_SCHEMA=gym

# ---- Auth (SERVER-ONLY) ----
# Long random string used to sign admin JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# Admin session lifetime. Spec: 8 hours.
JWT_EXPIRES_IN=8h
# bcrypt cost factor for admin password hashing.
BCRYPT_ROUNDS=12

# ---- One-time owner seed (used by `npm run seed:owner`) ----
SEED_OWNER_USERNAME=owner
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
SEED_OWNER_FULLNAME=Gym Owner

# ---- Phase 3: Payments (Paystack) ----
# Get TEST keys from https://dashboard.paystack.com/#/settings/developers
# The app builds/runs without these; live charging needs them set.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# In the Paystack dashboard, set the webhook URL to:
#   https://YOUR-DOMAIN/api/payments/webhook

# ---- Phase 5: Notifications ----
# Email via Brevo (300 free/day). https://app.brevo.com
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=
# Owner alerts via CallMeBot. WhatsApp + Telegram each need one-time activation.
# WhatsApp:  https://www.callmebot.com/blog/free-api-whatsapp-messages/
# Telegram:  https://www.callmebot.com/blog/telegram-text-messages/
OWNER_EMAIL=
CALLMEBOT_WHATSAPP_PHONE=
CALLMEBOT_WHATSAPP_APIKEY=
CALLMEBOT_TELEGRAM_USERNAME=
# (These can also be set per-gym in the admin Settings panel, Phase 7.)

# ---- Phase 8: Automation (cron) ----
# Secret to authorize cron endpoints when triggered manually or via an external
# scheduler. On Vercel, scheduled crons are trusted automatically. Generate:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=

# ============================================================
# The variables below are NOT needed yet. Leave blank for now.
# ============================================================

# ---- Phase 2: AI Chatbot (Anthropic) ----
# ANTHROPIC_API_KEY=
